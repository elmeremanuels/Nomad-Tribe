{
  "entities": {
    "FamilyProfile": {
      "title": "Family Profile",
      "description": "Core user profile containing family details, preferences, and nomad journey data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "familyName": { "type": "string" },
        "bio": { "type": "string" },
        "travelReasons": { "type": "array", "items": { "type": "string" } },
        "nativeLanguage": { "type": "string" },
        "spokenLanguages": { "type": "array", "items": { "type": "string" } },
        "parents": { "type": "array", "items": { "$ref": "#/entities/Parent" } },
        "kids": { "type": "array", "items": { "$ref": "#/entities/Kid" } },
        "isPremium": { "type": "boolean" },
        "premiumType": { "type": "string", "enum": ["NONE", "MONTHLY", "ANNUAL", "LIFETIME", "TRIAL"] },
        "role": { "type": "string", "enum": ["User", "UserPlus", "SuperAdmin", "Advertiser"] },
        "hasCompletedOnboarding": { "type": "boolean" },
        "currentLocation": { "$ref": "#/entities/PlaceResult" },
        "vibeFamilyMetrics": { "type": "object" },
        "lastVibeCheck": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "familyName", "role"]
    },
    "Parent": {
      "title": "Parent",
      "description": "Details of a parent in a family.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Kid": {
      "title": "Kid",
      "description": "Details of a kid in a family.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Boy", "Girl", "Non-binary"] },
        "interests": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PlaceResult": {
      "title": "Place Result",
      "description": "Google Place data structure.",
      "type": "object",
      "properties": {
        "placeId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      }
    },
    "Trip": {
      "title": "Trip",
      "description": "A planned or current trip for a family.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "familyId": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "required": ["id", "familyId", "startDate", "endDate"]
    },
    "Spot": {
      "title": "Spot",
      "description": "A family-friendly location like a playground or restaurant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "place": { "$ref": "#/entities/PlaceResult" },
        "isVetted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "category", "place"]
    },
    "LookingForRequest": {
      "title": "Looking For Request",
      "description": "A community request for help, playdates, or gear.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "createdAt"]
    },
    "MarketItem": {
      "title": "Market Item",
      "description": "An item for sale or swap in the marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["Available", "Reserved", "Sold"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sellerId", "title", "status"]
    },
    "PopUpEvent": {
      "title": "Pop-Up Event",
      "description": "A community-organized event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "organizerId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "organizerId", "title", "date"]
    },
    "CollabAsk": {
      "title": "Collab Ask",
      "description": "A professional help request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "skillNeeded": { "type": "string" },
        "description": { "type": "string" },
        "locationSlug": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "skillNeeded", "createdAt"]
    },
    "CollabEndorsement": {
      "title": "Collab Endorsement",
      "description": "Professional feedback/vouching.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetUserId": { "type": "string" },
        "authorId": { "type": "string" },
        "skill": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "targetUserId", "authorId", "skill", "createdAt"]
    },
    "AppNotification": {
      "title": "App Notification",
      "description": "User notification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "isRead", "createdAt"]
    },
    "Topic": {
      "title": "Topic",
      "description": "Admin-curated discussion channel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "isLocked": { "type": "boolean" },
        "threadCount": { "type": "number" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "order"]
    },
    "Thread": {
      "title": "Thread",
      "description": "Community discussion thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "region": { "type": "string" },
        "status": { "type": "string" },
        "replyCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "topicId", "authorId", "title", "status"]
    },
    "ThreadReply": {
      "title": "Thread Reply",
      "description": "Reply to a discussion thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "threadId": { "type": "string" },
        "authorId": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "threadId", "authorId", "body"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "FamilyProfile",
      "description": "Collection of user profiles."
    },
    "trips/{tripId}": {
      "schema": "Trip",
      "description": "Collection of all family trips."
    },
    "spots/{spotId}": {
      "schema": "Spot",
      "description": "Collection of community-recommended spots."
    },
    "lookingFor/{requestId}": {
      "schema": "LookingForRequest",
      "description": "Collection of community requests."
    },
    "marketplace/{itemId}": {
      "schema": "MarketItem",
      "description": "Collection of items in the marketplace."
    },
    "events/{eventId}": {
      "schema": "PopUpEvent",
      "description": "Collection of community events."
    },
    "connections/{connectionId}": {
      "schema": "object",
      "description": "User connections/friendships."
    },
    "conversations/{conversationId}": {
      "schema": "object",
      "description": "Chat conversations."
    },
    "collabAsks/{askId}": {
      "schema": "CollabAsk",
      "description": "Professional asks/requests."
    },
    "collabEndorsements/{endorsementId}": {
      "schema": "CollabEndorsement",
      "description": "Professional endorsements."
    },
    "notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "User notifications."
    },
    "topics/{topicId}": {
      "schema": "Topic",
      "description": "Curated community topics."
    },
    "threads/{threadId}": {
      "schema": "Thread",
      "description": "Community threads."
    },
    "threadReplies/{replyId}": {
      "schema": "ThreadReply",
      "description": "Replies to community threads."
    },
    "topicFollows/{id}": {
      "schema": "object",
      "description": "Topic follow relationships."
    },
    "threadFollows/{id}": {
      "schema": "object",
      "description": "Thread follow relationships."
    }
  }
}
