rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isSuper() {
      return isSignedIn() && request.auth.token.email.lower() == 'e.emanuels@gmail.com';
    }
    function isAdmin() { 
      return isSuper() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin');
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Entity Validators
    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'familyName', 'role']) &&
             data.id == request.auth.uid &&
             data.familyName is string && data.familyName.size() <= 100 &&
             data.role in ['User', 'UserPlus', 'SuperAdmin', 'Advertiser'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'message', 'type', 'isRead', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 1000;
    }

    function isValidCollabAsk(data) {
      return data.keys().hasAll(['id', 'userId', 'skillNeeded', 'description', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.skillNeeded is string && data.skillNeeded.size() <= 100 &&
             data.description is string && data.description.size() <= 600;
    }

    function isValidCollabEndorsement(data) {
      return data.keys().hasAll(['id', 'targetUserId', 'authorId', 'skill', 'comment', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.comment is string && data.comment.size() <= 1000;
    }

    // 3. Collection Rules
    
    // USERS
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isSuper() || resource.data.id != null);
      allow create: if isVerified() && isValidId(userId) && isValidProfile(incoming());
      allow update: if isVerified() && isOwner(userId) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['familyName', 'bio', 'travelReasons', 'nativeLanguage', 'spokenLanguages', 'parents', 'kids', 'currentLocation', 'vibeFamilyMetrics', 'lastVibeCheck', 'hasCompletedOnboarding', 'openToCollabs', 'privacySettings', 'preferences', 'collabCard', 'photoUrl'])) &&
        incoming().role == existing().role &&
        incoming().id == existing().id
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isSuper() || resource.data.userId == request.auth.uid);
      allow create: if isVerified() && (isValidNotification(incoming()) || isAdmin());
      allow update: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])
      );
      allow delete: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // COLLAB ASKS
    match /collabAsks/{askId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.id != null;
      allow create: if isVerified() && isValidId(askId) && isValidCollabAsk(incoming());
      allow update: if isVerified() && (existing().userId == request.auth.uid || isAdmin()) && isValidCollabAsk(incoming());
      allow delete: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
    }

    // COLLAB ENDORSEMENTS
    match /collabEndorsements/{endorsementId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.id != null;
      allow create: if isVerified() && isValidId(endorsementId) && isValidCollabEndorsement(incoming());
      allow delete: if isVerified() && (existing().authorId == request.auth.uid || isAdmin());
    }

    // TRIPS
    match /trips/{tripId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(tripId) && incoming().familyId == request.auth.uid;
      allow update, delete: if isVerified() && (existing().familyId == request.auth.uid || isAdmin());
    }

    // SPOTS
    match /spots/{spotId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(spotId);
      allow update: if isVerified() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'category', 'imageUrl', 'place', 'tags', 'votes']) && !incoming().diff(existing()).affectedKeys().hasAny(['isVetted', 'isHidden'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // LOOKING FOR
    match /lookingFor/{requestId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(requestId) && incoming().userId == request.auth.uid;
      allow update, delete: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
    }

    // MARKETPLACE
    match /marketplace/{itemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(itemId) && incoming().sellerId == request.auth.uid;
      allow update: if isVerified() && (
        (existing().sellerId == request.auth.uid) ||
        (incoming().status == 'Reserved' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reservedBy', 'reservedUntil'])) ||
        isAdmin()
      );
      allow delete: if isVerified() && (existing().sellerId == request.auth.uid || isAdmin());
    }

    // EVENTS
    match /events/{eventId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(eventId) && incoming().organizerId == request.auth.uid;
      allow update: if isVerified() && (
        (existing().organizerId == request.auth.uid) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['participants', 'waitlist'])) ||
        isAdmin()
      );
      allow delete: if isVerified() && (existing().organizerId == request.auth.uid || isAdmin());
    }

    // CONNECTIONS
    match /connections/{connectionId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isVerified() && request.auth.uid in incoming().participantIds;
      allow update: if isVerified() && request.auth.uid in existing().participantIds;
      allow delete: if isVerified() && request.auth.uid in existing().participantIds;
    }

    // MESSAGES (Top-level in code)
    match /messages/{messageId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isVerified() && isValidId(messageId) && request.auth.uid == incoming().senderId && request.auth.uid in incoming().participantIds;
    }
    
    // CONVERSATIONS
    match /conversations/{conversationId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isVerified() && request.auth.uid in incoming().participantIds;
      allow update: if isVerified() && request.auth.uid in existing().participantIds;
    }
    
    // Remaining collections
    match /settings/global {
      allow read: if true;
    }
    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /destinations/{id} { 
      allow read: if isSignedIn() && (isSuper() || resource.data.id != null);
      allow write: if isAdmin(); 
    }
    match /cities/{id} { 
      allow read: if isSignedIn() && (isSuper() || resource.data.id != null);
      allow write: if isAdmin(); 
    }
    match /cityEvents/{id} { 
      allow read: if isSignedIn() && (isSuper() || resource.data.id != null);
      allow write: if isVerified(); 
    }
    match /pastPlaces/{id} { 
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuper()); 
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update, delete: if isVerified() && (resource.data.userId == request.auth.uid || isSuper());
    }
    match /activities/{id} { 
      allow read: if isSignedIn() && (isSuper() || resource.data.id != null);
      allow create: if isVerified(); 
    }
    match /deals/{id} { 
      allow read: if isSignedIn() && (isSuper() || resource.data.id != null);
      allow write: if isAdmin(); 
    }
    match /advertisers/{id} { 
      allow read: if isSignedIn() && (isSuper() || resource.data.id != null);
      allow write: if isAdmin(); 
    }
    match /reports/{id} { 
      allow create: if isVerified(); 
      allow read, update: if isAdmin(); 
    }
    match /blocks/{id} { 
      allow read: if isVerified() && (resource.data.blockerId == request.auth.uid || isSuper()); 
      allow create: if isVerified() && incoming().blockerId == request.auth.uid;
      allow update, delete: if isVerified() && (resource.data.blockerId == request.auth.uid || isSuper()); 
    }
  }
}
